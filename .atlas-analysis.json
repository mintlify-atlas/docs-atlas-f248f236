  "keyFeatures": [
    "Import-only music library with automatic persistence",
    "Hand-curated rotation system for daily listening",
    "Automatic offline mode with download-on-stream",
    "Multi-rotation support for different listening contexts",
    "Interactive listening graph visualization",
    "Multi-source music import (Bandcamp, Spotify, YouTube, Last.fm)",
    "PageRank-based song discovery and recommendations",
    "Directed weighted graph of listening patterns",
    "Real-time graph analysis and clustering"
  ],
  "publicApiSurface": [
    "GET /graph - Retrieve user's listening graph",
    "GET /graph/node/:id - Get single node details",
    "GET /graph/neighbors/:id - Get node neighbors",
    "GET /graph/stats - Get graph statistics",
    "GET /graph/analysis - Get enriched analysis data",
    "GET /graph/path - Find paths between songs",
    "POST /pipeline/fetch/lastfm - Fetch Last.fm scrobbles",
    "POST /pipeline/build - Build graph from data",
    "POST /pipeline/run - Queue full pipeline job",
    "GET /pipeline/run/:jobId - Check job status",
    "PlayerView component - Main music player UI",
    "GraphView component - Listening graph visualization",
    "SongKey type - Canonical song identity format",
    "GraphNode interface - Graph node structure",
    "ListeningGraph interface - Complete graph structure"
